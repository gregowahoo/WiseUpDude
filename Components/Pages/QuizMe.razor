@page "/quizme"
@inject NavigationManager NavigationManager

@inject QuizTopicService_Gemini QuizTopicService_Gemini
@inject QuizTopicService_OpenAI QuizTopicService_OpenAI

<div class="container mt-5">
    <!-- Header -->
    <div class="text-center mb-4">
        <h2 class="fw-bold">🎯 Quiz Me!</h2>
        <p class="text-muted">Type a topic you're curious about, pick a difficulty, and go!</p>
    </div>

    <!-- Input Box -->
    <div class="row justify-content-center">
        <div class="col-md-8">
            <label for="topicInput" class="form-label fw-semibold">What do you want to learn today?</label>
            <InputText id="topicInput" @bind-Value="UserTopic" class="form-control form-control-lg mb-3"
                       placeholder="e.g. Space exploration, Taylor Swift, World War II" />

            <!-- Suggested Prompts -->
            <div class="d-flex flex-wrap gap-2 mb-3">
                @foreach (var suggestion in SuggestedTopics)
                {
                    <button class="btn btn-outline-secondary btn-sm rounded-pill"
                            @onclick="@(() => UserTopic = suggestion)">
                        @suggestion
                    </button>
                }
            </div>

            <!-- Difficulty Selection -->
            <label class="form-label fw-semibold">Choose Difficulty:</label>
            <div class="btn-group w-100 mb-4" role="group">
                @foreach (var level in DifficultyLevels)
                {
                    <input type="radio"
                           class="btn-check"
                           name="difficulty"
                           id="@level"
                           value="@level"
                           @onchange="() => SelectedDifficulty = level"
                           checked="@(SelectedDifficulty == level)" />
                    <label class="btn btn-outline-primary" for="@level">@level</label>
                }
            </div>

            <!-- Start Button -->
            <div class="text-center">
                <button class="btn btn-success btn-lg px-5" @onclick="GenerateQuiz">
                    🚀 Generate Quiz
                </button>
            </div>
        </div>
    </div>
</div>
@code {

    private string? UserTopic { get; set; }
    private string SelectedDifficulty { get; set; } = "Medium";

    private readonly string[] SuggestedTopics = new[]
    {
        "Space Exploration", "Taylor Swift", "World War II", "The Great Gatsby", "Artificial Intelligence",
        "The Beatles", "Climate Change", "The Renaissance", "The Solar System", "The French Revolution",
        "History of AI", "Fun facts about dogs", "Investing basics", "Space trivia"
    };

    private readonly string[] DifficultyLevels = new[] { "Easy", "Medium", "Hard" };

    private void GenerateQuiz()
    {
        // Need to get the questions from Open AI API here...
        
        // Redirect to the quiz page with the selected topic and difficulty
        //NavigationManager.NavigateTo($"/takequiz?topic={UserTopic}&difficulty={SelectedDifficulty}");
    }
}