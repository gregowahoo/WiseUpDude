@page "/home"

@layout WiseUpDude.Components.Layout.MinimalLayout

@using WiseUpDude.Services
@using WiseUpDude.Model

@inject QuizStateService QuizState
@inject NavigationManager NavManager

@rendermode InteractiveServer

<h1 class="text-center mt-4">Welcome to Your Dashboard</h1>

<div class="container mt-5">
    <div class="row">
        <!-- Summary Card -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm text-center p-4">
                <h5>Total Quizzes Taken</h5>
                <p class="display-4">@TotalQuizzesTaken</p>
            </div>
        </div>

        <!-- Average Score Card -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm text-center p-4">
                <h5>Average Score</h5>
                <p class="display-4">@AverageScore%</p>
            </div>
        </div>

        <!-- Best Quiz Card -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm text-center p-4">
                <h5>Best Quiz</h5>
                <p>@BestQuizTitle</p>
                <p class="text-success">Score: @BestQuizScore%</p>
            </div>
        </div>
    </div>

    <!-- Recent Quizzes Section -->
    <div class="mt-5">
        <h3>Recent Quizzes</h3>
        @if (RecentQuizzes?.Any() == true)
        {
            <ul class="list-group">
                @foreach (var quiz in RecentQuizzes)
                {
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span>@quiz.Name</span>
                        <span class="badge bg-primary rounded-pill">@quiz.Score%</span>
                    </li>
                }
            </ul>
        }
        else
        {
            <p>No quizzes taken yet. Start your learning journey now!</p>
        }
    </div>

    <!-- Call-to-Action Section -->
    <div class="text-center mt-5">
        <a class="btn btn-success btn-lg" href="/pickatopic">Take a New Quiz</a>
    </div>
</div>

@code {
    private int TotalQuizzesTaken { get; set; }
    private double AverageScore { get; set; }
    private string BestQuizTitle { get; set; } = "N/A";
    private double BestQuizScore { get; set; }
    private List<UserQuiz> RecentQuizzes { get; set; } = new();

    protected override async Task OnInitializedAsync()
    {
        // Simulate fetching data (replace with actual service calls)
        await LoadQuizDataAsync();
    }

    private async Task LoadQuizDataAsync()
    {
        // Example: Replace with actual data fetching logic
        RecentQuizzes = new List<UserQuiz>
        {
            new UserQuiz { Name = "World War II", Score = 85 },
            new UserQuiz { Name = "Photosynthesis", Score = 90 },
            new UserQuiz { Name = "Periodic Table", Score = 75 }
        };

        TotalQuizzesTaken = RecentQuizzes.Count;
        AverageScore = RecentQuizzes.Any() ? RecentQuizzes.Average(q => q.Score) : 0;
        var bestQuiz = RecentQuizzes.OrderByDescending(q => q.Score).FirstOrDefault();
        if (bestQuiz != null)
        {
            BestQuizTitle = bestQuiz.Name;
            BestQuizScore = bestQuiz.Score;
        }

        await Task.CompletedTask;
    }

    // Example UserQuiz model (replace with actual model)
    private class UserQuiz
    {
        public string Name { get; set; } = string.Empty;
        public double Score { get; set; }
    }
}
