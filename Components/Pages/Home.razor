@page "/home"

@layout WiseUpDude.Components.Layout.MinimalLayout

@using Microsoft.AspNetCore.Components.Authorization
@using WiseUpDude.Model
@using WiseUpDude.Services
@using WiseUpDude.Data.Repositories
@using WiseUpDude.Data.Repositories.Interfaces

@inject DashboardDataService DashboardData
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavManager
@inject IUserRepository<Quiz> QuizRepository
@inject QuizStateService QuizState

@rendermode InteractiveServer

<h1 class="text-center">Welcome to Wise Up Dude!</h1>

<div class="container mt-3">
    <div class="row">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm text-center p-4">
                <h5>Total Quizzes Taken</h5>
                <p class="display-4">@Summary?.TotalQuizzesTaken</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm text-center p-4">
                <h5>Average Score</h5>
                <p class="display-4">@($"{Summary?.AverageScore:F0}%")</p>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm text-center p-4">
                <h5>Best Quiz</h5>
                <p>@(Summary?.BestQuizName ?? "N/A")</p>
                <p class="text-success">Score: @($"{Summary?.BestQuizScore ?? 0:F0}%")</p>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <h3>Your Saved Quizzes</h3>
        @if (IsGenerating)
        {
            <p class="text-center text-muted">🦖 Generating your quiz...</p>
        }
        else if (Summary == null)
        {
            <p>Loading...</p>
        }
        else if (Summary.RecentQuizzes?.Any() == true)
        {
            <ul class="list-group list-unstyled">
                @foreach (var quiz in Summary?.RecentQuizzes ?? new List<RecentQuizDto>())
                {
                    var scoreClass = quiz.Score >= 80 ? "score-high" : quiz.Score >= 50 ? "score-mid" : "score-low";
                    <li class="list-group-item quiz-card">
                        <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between">
                            <div class="flex-grow-1">
                                <input type="hidden" value="@quiz.Id" />

                                @if (quiz.Type == "Prompt" && !string.IsNullOrWhiteSpace(quiz.Prompt))
                                {
                                    <span class="badge bg-orange text-dark fw-bold">Prompt:</span>
                                    <span class="ms-1">@quiz.Prompt</span>
                                    <span class="badge rounded-pill ms-2 score-pill @scoreClass" style="margin-bottom: 2px;">@($"{quiz.Score:F0}%")</span>
                                }
                                else if (!string.IsNullOrWhiteSpace(quiz.Topic))
                                {
                                    <span class="badge bg-info text-dark fw-bold">Topic:</span>
                                    <span class="ms-1">@quiz.Topic</span>
                                    <span class="badge rounded-pill ms-2 score-pill @scoreClass" style="margin-bottom: 2px;">@($"{quiz.Score:F0}%")</span>
                                }

                                @if (!string.IsNullOrWhiteSpace(quiz.Description))
                                {
                                    <div class="text-muted" style="font-size: 0.85em; max-width: 100%; word-break: break-word;">
                                        @quiz.Description
                                    </div>
                                }

                                <div class="d-flex flex-column gap-2 mt-1">
                                    <div class="d-flex align-items-center flex-wrap gap-2">
                                        <span style="font-size: 0.85em; white-space: nowrap;">Quiz Name:</span>
                                        @if (editingQuizId == quiz.Id)
                                        {
                                            <input type="text" class="form-control form-control-sm" style="width: auto; font-size: 0.85em;" @bind="quiz.Name" />
                                            <button class="btn btn-sm btn-primary" @onclick="() => SaveQuizName(quiz)">Save</button>
                                            <button class="btn btn-sm btn-secondary" @onclick="CancelEdit">Cancel</button>
                                        }
                                        else
                                        {
                                            <div class="d-inline-flex align-items-center gap-1 flex-nowrap">
                                                <a href="#" @onclick="() => ResumeQuiz(quiz.Id)" class="text-decoration-none fw-bold" style="font-size: 0.85em; white-space: nowrap;">
                                                    @quiz.Name
                                                </a>
                                                <button class="btn btn-sm text-primary border-0 bg-transparent" title="Edit" @onclick="() => EditQuiz(quiz.Id)">
                                                    <i class="bi bi-pencil fs-6"></i>
                                                </button>
                                            </div>
                                        }
                                    </div>

                                    @if (editingQuizId != quiz.Id)
                                    {
                                        <div class="btn-toolbar mt-1" role="toolbar">
                                            <div class="btn-group me-2 gap-2" role="group">
                                                <button class="btn btn-sm text-primary border-0 bg-transparent" title="Resume" @onclick="() => ResumeQuiz(quiz.Id)">
                                                    <i class="bi bi-play-fill fs-6"></i>
                                                </button>
                                                <button class="btn btn-sm text-success border-0 bg-transparent" title="Start Fresh" @onclick="() => StartFresh(quiz.Id)">
                                                    <i class="bi bi-arrow-clockwise fs-6"></i>
                                                </button>
                                                <button class="btn btn-sm text-secondary border-0 bg-transparent" title="Delete" @onclick="() => ConfirmDelete(quiz.Id)">
                                                    <i class="bi bi-trash fs-6"></i>
                                                </button>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </li>
                }
            </ul>
        }
        else
        {
            <p>No quizzes taken yet. Start your learning journey now!</p>
        }
    </div>

    <div class="text-center mt-4">
        <a class="btn btn-success btn-lg" href="/pickatopic">Take a New Quiz</a>
    </div>
</div>

@if (quizToDeleteId.HasValue)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0, 0, 0, 0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Confirm Delete</h5>
                    <button type="button" class="btn-close" @onclick="CancelDelete"></button>
                </div>
                <div class="modal-body">
                    <p>Are you sure you want to delete this quiz?</p>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="CancelDelete">Cancel</button>
                    <button class="btn btn-danger" @onclick="ConfirmedDelete">Delete</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private int? editingQuizId = null;
    private DashboardSummaryDto? Summary;
    private bool IsGenerating = false;
    private int? quizToDeleteId = null;

    private void EditQuiz(int quizId) => editingQuizId = quizId;
    private void CancelEdit() => editingQuizId = null;

    private async Task SaveQuizName(RecentQuizDto quiz)
    {
        await QuizRepository.UpdateQuizNameAsync(quiz.Id, quiz.Name);
        editingQuizId = null;
    }

    private async Task DeleteQuiz(int quizId)
    {
        try
        {
            await QuizRepository.DeleteAsync(quizId);
            var quizToRemove = Summary?.RecentQuizzes?.FirstOrDefault(q => q.Id == quizId);
            if (quizToRemove != null)
            {
                Summary.RecentQuizzes.Remove(quizToRemove);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting quiz: {ex.Message}");
        }
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        if (user.Identity?.IsAuthenticated == true)
        {
            var userId = user.FindFirst(c => c.Type == "sub" || c.Type.EndsWith("nameidentifier"))?.Value;
            if (!string.IsNullOrEmpty(userId))
            {
                Summary = await DashboardData.GetDashboardSummaryAsync(userId);
            }
        }
    }

    private async Task ResumeQuiz(int quizId)
    {
        IsGenerating = true;
        try
        {
            var selectedQuiz = await QuizRepository.GetByIdAsync(quizId);
            if (selectedQuiz != null)
            {
                QuizState.CurrentQuiz = new Quiz
                    {
                        Id = selectedQuiz.Id,
                        Name = selectedQuiz.Name,
                        Questions = selectedQuiz.Questions,
                        UserName = selectedQuiz.UserName,
                        User = selectedQuiz.User,
                        Type = selectedQuiz.Type,
                        Topic = selectedQuiz.Topic,
                        TopicId = selectedQuiz.TopicId,
                        Prompt = selectedQuiz.Prompt,
                        Description = selectedQuiz.Description,
                        Difficulty = selectedQuiz.Difficulty
                    };
                NavManager.NavigateTo("/TakeQuiz");
            }
            else
            {
                Console.WriteLine("🛛 No quiz found for the selected ID.");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error during quiz fetch: {ex.Message}");
        }
        finally
        {
            IsGenerating = false;
        }
    }

    private async Task StartFresh(int quizId)
    {
        IsGenerating = true;
        try
        {
            var selectedQuiz = await QuizRepository.GetByIdAsync(quizId);
            if (selectedQuiz != null)
            {
                QuizState.CurrentQuiz = new Quiz
                    {
                        Id = selectedQuiz.Id,
                        Name = selectedQuiz.Name,
                        Questions = selectedQuiz.Questions,
                        UserName = selectedQuiz.UserName,
                        User = selectedQuiz.User,
                        Type = selectedQuiz.Type,
                        Topic = selectedQuiz.Topic,
                        TopicId = selectedQuiz.TopicId,
                        Prompt = selectedQuiz.Prompt,
                        Description = selectedQuiz.Description,
                        Difficulty = selectedQuiz.Difficulty
                    };
                foreach (var question in QuizState.CurrentQuiz.Questions)
                {
                    question.UserAnswer = null;
                }
                NavManager.NavigateTo("/TakeQuiz");
            }
            else
            {
                Console.WriteLine("🛛 No quiz found for the selected ID.");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error during quiz fetch: {ex.Message}");
        }
        finally
        {
            IsGenerating = false;
        }
    }

    private void ConfirmDelete(int quizId) => quizToDeleteId = quizId;
    private void CancelDelete() => quizToDeleteId = null;

    private async Task ConfirmedDelete()
    {
        if (quizToDeleteId.HasValue)
        {
            try
            {
                await QuizRepository.DeleteAsync(quizToDeleteId.Value);
                var quizToRemove = Summary?.RecentQuizzes?.FirstOrDefault(q => q.Id == quizToDeleteId.Value);
                if (quizToRemove != null)
                {
                    Summary.RecentQuizzes.Remove(quizToRemove);
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error deleting quiz: {ex.Message}");
            }
            finally
            {
                quizToDeleteId = null;
            }
        }
    }
}
