@page "/quiz"

@rendermode InteractiveServer

@using WiseUpDude.Services
@using WiseUpDude.Components.Controls
@using WiseUpDude.Model

@inject QuizStateService QuizState
@inject QuizService QuizService

@attribute [Authorize]

<div class="container mt-4">
    <h3>Quiz Questions</h3>
    <p class="text-muted">Select an answer for each question to see if you’re correct.</p>

    <div class="form-check mb-3">
        <input class="form-check-input" type="checkbox" id="autoSubmit" @bind="autoSubmit">
        <label class="form-check-label" for="autoSubmit">
            Auto Submit Answers
        </label>
    </div>

    @if (QuizState?.CurrentQuiz == null || QuizState.CurrentQuiz.Questions.Count == 0)
    {
        <div class="alert alert-warning">
            No quiz questions found. Please go to Home and generate a quiz first.
        </div>
    }
    else
    {
        @for (int i = 0; i < QuizState.CurrentQuiz.Questions.Count; i++)
        {
            var question = QuizState.CurrentQuiz.Questions[i];
            <QuestionCard Question="question" QuestionIndex="i" AutoSubmit="autoSubmit" />
        }

        <button class="btn btn-primary mt-3" @onclick="SaveQuiz">Save Quiz</button>
    }
</div>

@code {
    private bool autoSubmit = true;

    private async Task SaveQuiz()
    {
        if (QuizState?.CurrentQuiz != null)
        {
            var quiz = new Quiz
            {
                Title = "Generated Quiz",
                UserId = "current_user_id", // Replace with actual user ID
                Questions = QuizState.CurrentQuiz.Questions
            };

            await QuizService.SaveQuizAsync(quiz);
        }
    }
}
