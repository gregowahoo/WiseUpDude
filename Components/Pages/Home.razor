@page "/"

<div class="container mt-5">

    <!-- Hero Section -->
    <div class="text-center mb-5">
        <h1 class="display-4 fw-bold">Wise Up Dude</h1>
        <p class="lead">The fun, social way to learn, compete, and create quizzes.</p>
        <a href="/quizme" class="btn btn-primary btn-lg mt-3">Create Your First Quiz Now</a>
    </div>

    <!-- How It Works -->
    <div class="row text-center mb-5">
        <div class="col-md-4">
            <h3>📚 Pick a Topic</h3>
            <p>Select a category or type what you want to learn about.</p>
        </div>
        <div class="col-md-4">
            <h3>🧠 Take a Quiz</h3>
            <p>Answer fun, engaging questions generated just for you.</p>
        </div>
        <div class="col-md-4">
            <h3>🏆 Compete & Create</h3>
            <p>Challenge friends or build your own quizzes to share.</p>
        </div>
    </div>

    <!-- Why It's Awesome -->
    <div class="row mb-5">
        <div class="col-md-6">
            <h4>🔁 Personalized Learning</h4>
            <p>Get smarter about what interests you—no boring lectures.</p>
        </div>
        <div class="col-md-6">
            <h4>🎉 Social and Fun</h4>
            <p>Save your favorite questions, build super quizzes, and go head-to-head with others.</p>
        </div>
    </div>

    <!-- Final CTA -->
    <div class="text-center">
        <a href="/quizme" class="btn btn-success btn-lg">Jump In Now!</a>
    </div>

</div>
