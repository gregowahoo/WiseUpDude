@page "/home2"
@layout WiseUpDude.Components.Layout.MinimalLayout

@using WiseUpDude.Services
@using WiseUpDude.Model
@using WiseUpDude.Data
@using WiseUpDude.Components.Controls

@* @inject QuizService QuizService *@
@inject NavigationManager NavManager

<h1 class="title">Dashboard</h1>

<div class="container">
    <!-- Quiz Results Section -->
    <section>
        <h2>Quiz Results</h2>
        @if (quizzes == null)
        {
            <p>Loading...</p>
        }
        else if (quizzes.Count == 0)
        {
            <p>No quizzes taken yet.</p>
        }
        else
        {
            <table class="table">
                <thead>
                    <tr>
                        <th>Quiz Name</th>
                        <th>Date Taken</th>
                        <th>Score</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var quiz in quizzes)
                    {
                        <tr>
                            <td>@quiz.Name</td>
                            <td></td>
                            <td></td>
@*                          <td>@quiz.DateTaken.ToString("MM/dd/yyyy")</td>
                            <td>@quiz.Score</td> *@
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>

    <!-- Settings Section -->
    <section>
        <h2>Settings</h2>
        <div class="form-group">
            <label for="difficulty">Default Difficulty Level</label>
            <select id="difficulty" @bind="defaultDifficulty" class="form-control">
                <option value="Easy">Easy</option>
                <option value="Medium">Medium</option>
                <option value="Hard">Hard</option>
            </select>
        </div>
        <button class="btn btn-primary" @onclick="SaveSettings">Save Settings</button>
    </section>
</div>

@code {
    private List<Quiz> quizzes;
    private string defaultDifficulty;

    protected override async Task OnInitializedAsync()
    {
        // quizzes = await QuizService.GetAllQuizzesAsync();
        defaultDifficulty = "Medium"; // Load from settings if available
    }

    private async Task SaveSettings()
    {
        // Save settings logic here
        Console.WriteLine($"Settings saved: Default Difficulty - {defaultDifficulty}");
        await Task.CompletedTask; // Simulate save
    }
}